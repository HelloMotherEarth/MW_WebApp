# Copy this file to `.env` and fill in your real values.
# Do NOT commit `.env` to source control.

# SQL Server example
DB_HOST=localhost
DB_PORT=1433
DB_NAME=MyDatabase
DB_USER=app_user
DB_PASSWORD=replace_me
DB_TIMESTAMP_TIMEZONE=UTC
APP_TIMEZONE=America/Los_Angeles
CORS_ALLOW_ORIGINS=http://localhost:5173,https://www.charliecoultas.com

# Frontend (Vercel) should point at your deployed API origin (no /api suffix).
# Example: https://your-render-service.onrender.com
VITE_API_BASE_URL=

# Optional: full connection string pattern
# DB_CONNECTION_STRING=Server=${DB_HOST},${DB_PORT};Database=${DB_NAME};User Id=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True;
